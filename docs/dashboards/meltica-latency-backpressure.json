{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(meltica_databus_publish_duration_bucket{environment=\"$environment\",provider=~\"$provider\"}[5m])) by (le, provider))",
          "legendFormat": "p95 {{provider}}",
          "refId": "A"
        }
      ],
      "title": "Publish Latency p95",
      "type": "heatmap"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_databus_delivery_blocked{environment=\"$environment\"}[5m])) by (provider)",
          "legendFormat": "blocked {{provider}}",
          "refId": "A"
        }
      ],
      "title": "Blocked Deliveries",
      "type": "heatmap"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "sum(meltica_databus_subscribers{environment=\"$environment\",event_type=~\"$event_type\"}) by (provider, event_type)",
          "legendFormat": "{{provider}} {{event_type}}",
          "refId": "A"
        }
      ],
      "title": "Subscriber Pressure",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {
                "color": "rgba(108, 207, 246, 1)",
                "value": null
              },
              {
                "color": "rgba(240, 180, 0, 1)",
                "value": 0.75
              },
              {
                "color": "rgba(240, 0, 0, 1)",
                "value": 1
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_databus_delivery_blocked{environment=\"$environment\"}[5m])) / clamp_min(sum(rate(meltica_databus_events_published{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\"}[5m])), 1e-6)",
          "legendFormat": "blocked ratio",
          "refId": "A"
        }
      ],
      "title": "Blocked Ratio",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "content": "### Alerting Guidance\n- Trigger **Warn** when publish latency p95 > 150ms for 5m.\n- Trigger **Critical** when blocked ratio > 5% or subscriber count exceeds threshold.\n- Add alerts for sudden drops in frames processed per provider.",
        "mode": "markdown"
      },
      "type": "text"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
    "meltica",
    "performance"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1
      },
      {
        "current": {
          "text": "production",
          "value": "production"
        },
        "datasource": {
          "uid": "$datasource"
        },
        "label": "Environment",
        "name": "environment",
        "query": "label_values(meltica_databus_events_published, environment)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {
          "text": ".*",
          "value": ".*"
        },
        "datasource": {
          "uid": "$datasource"
        },
        "includeAll": true,
        "label": "Provider",
        "multi": true,
        "name": "provider",
        "query": "label_values(meltica_databus_events_published, provider)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {
          "text": ".*",
          "value": ".*"
        },
        "datasource": {
          "uid": "$datasource"
        },
        "includeAll": true,
        "label": "Event Type",
        "multi": true,
        "name": "event_type",
        "query": "label_values(meltica_databus_events_published, event_type)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m"
    ]
  },
  "timezone": "browser",
  "title": "Meltica - Latency & Backpressure Watch",
  "uid": "meltica-latency-backpressure",
  "version": 1
}