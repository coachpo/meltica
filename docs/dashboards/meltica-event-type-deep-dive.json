{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_databus_events_published{environment=\"$environment\",provider=~\"$provider\",event_type=\"$event_type\",symbol=~\"$symbol\"}[1m]))",
          "legendFormat": "events/s",
          "refId": "A"
        }
      ],
      "title": "Selected Event Type Throughput",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum(rate(meltica_databus_events_published{environment=\"$environment\",provider=~\"$provider\",event_type=\"$event_type\",symbol!=\"\"}[5m])) by (symbol))",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "title": "Top Symbols by Event Volume",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "last"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(meltica_databus_publish_duration_bucket{environment=\"$environment\",provider=~\"$provider\",event_type=\"$event_type\",symbol=~\"$symbol\"}[5m])) by (le, provider))",
          "legendFormat": "p95 {{provider}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(meltica_databus_publish_duration_bucket{environment=\"$environment\",provider=~\"$provider\",event_type=\"$event_type\",symbol=~\"$symbol\"}[5m])) by (le, provider))",
          "legendFormat": "p99 {{provider}}",
          "refId": "B"
        }
      ],
      "title": "Latency Percentiles by Provider",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "custom": {
            "align": "auto"
          }
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_databus_events_published{environment=\"$environment\",provider=~\"$provider\",event_type=\"$event_type\",symbol!=\"\"}[5m])) by (provider, symbol)",
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "sum(rate(meltica_dispatcher_events_dropped{environment=\"$environment\",provider=~\"$provider\",event_type=\"$event_type\",symbol!=\"\"}[5m])) by (provider, symbol)",
          "format": "table",
          "refId": "B"
        }
      ],
      "title": "Per-Symbol Volume & Blocking",
      "transformations": [
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value": "Events/s",
              "Value 1": "Blocked/s"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 5,
      "options": {
        "content": "### Sequence Gap Monitoring\nAdditional telemetry (e.g., per-stream sequence gap counters) can enrich this dashboard. Consider instrumenting book assemblers with gap/error metrics to populate a future panel here.",
        "mode": "markdown"
      },
      "type": "text"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
    "meltica",
    "events"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1
      },
      {
        "current": {
          "text": "production",
          "value": "production"
        },
        "datasource": {
          "uid": "$datasource"
        },
        "label": "Environment",
        "name": "environment",
        "query": "label_values(meltica_databus_events_published, environment)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {
          "text": ".*",
          "value": ".*"
        },
        "datasource": {
          "uid": "$datasource"
        },
        "includeAll": true,
        "label": "Provider",
        "multi": true,
        "name": "provider",
        "query": "label_values(meltica_databus_events_published, provider)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {
          "text": "book_snapshot",
          "value": "book_snapshot"
        },
        "datasource": {
          "uid": "$datasource"
        },
        "label": "Event Type",
        "name": "event_type",
        "query": "label_values(meltica_databus_events_published, event_type)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {
          "text": ".*",
          "value": ".*"
        },
        "datasource": {
          "uid": "$datasource"
        },
        "includeAll": true,
        "label": "Symbol",
        "multi": true,
        "name": "symbol",
        "query": "label_values(meltica_databus_events_published, symbol)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m"
    ]
  },
  "timezone": "browser",
  "title": "Meltica - Event Type Deep Dive",
  "uid": "meltica-event-type",
  "version": 1
}
