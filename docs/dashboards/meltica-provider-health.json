{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "displayName": "Frames/s",
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.4.3",
      "targets": [
        {
          "expr": "sum(rate(wsclient_frames_processed_total{environment=\"$environment\",provider=~\"$provider\",message_type=~\"$message_type\"}[1m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "title": "Frame Intake",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.4.3",
      "targets": [
        {
          "expr": "sum(rate(wsclient_frames_errors_total{environment=\"$environment\",provider=~\"$provider\",operation=~\"$operation\"}[5m])) / clamp_min(sum(rate(wsclient_frames_processed_total{environment=\"$environment\",provider=~\"$provider\"}[5m])), 1e-6)",
          "legendFormat": "error ratio",
          "refId": "A"
        }
      ],
      "title": "Frame Error Ratio",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "last"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(wsclient_frame_processing_duration_bucket{environment=\"$environment\",provider=~\"$provider\",message_type=~\"$message_type\"}[5m])) by (le, provider))",
          "legendFormat": "p50 {{provider}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(wsclient_frame_processing_duration_bucket{environment=\"$environment\",provider=~\"$provider\",message_type=~\"$message_type\"}[5m])) by (le, provider))",
          "legendFormat": "p95 {{provider}}",
          "refId": "B"
        }
      ],
      "title": "Frame Processing Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 4,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(10, avg_over_time(wsclient_frame_processing_duration_sum{environment=\"$environment\",provider=~\"$provider\",message_type=~\"$message_type\"}[10m]) / clamp_min(avg_over_time(wsclient_frame_processing_duration_count{environment=\"$environment\",provider=~\"$provider\",message_type=~\"$message_type\"}[10m]), 1e-6))",
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Slowest Streams (last 10m avg)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value": "Latency (ms)"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2
          },
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "last"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(controlbus_send_duration_sum{environment=\"$environment\",command_type=~\"$command_type\"}[5m])) / clamp_min(sum(rate(controlbus_send_duration_count{environment=\"$environment\",command_type=~\"$command_type\"}[5m])), 1e-6)",
          "legendFormat": "ack latency",
          "refId": "A"
        },
        {
          "expr": "sum(rate(controlbus_send_errors_total{environment=\"$environment\",command_type=~\"$command_type\",status=~\"$status\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "B"
        }
      ],
      "title": "Control Bus Command Health",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
    "meltica",
    "provider"
  ],
