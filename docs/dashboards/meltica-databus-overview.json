      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              },
              {
                "color": "orange",
                "value": 150
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.4.3",
      "targets": [
        {
          "expr": "sum(rate(meltica_databus_events_published{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\",symbol=~\"$symbol\"}[5m]))",
          "legendFormat": "events/s",
          "refId": "A"
        }
      ],
      "title": "Publish Throughput",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.4.3",
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_dropped{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\",symbol=~\"$symbol\"}[5m])) / clamp_min(sum(rate(meltica_databus_events_published{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\",symbol=~\"$symbol\"}[5m])), 1e-6)",
          "legendFormat": "blocked ratio",
          "refId": "A"
        }
      ],
      "title": "Backpressure Ratio",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["last"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(meltica_databus_publish_duration_bucket{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\",symbol=~\"$symbol\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(meltica_databus_publish_duration_bucket{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\",symbol=~\"$symbol\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(meltica_databus_publish_duration_bucket{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\",symbol=~\"$symbol\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Publish Latency Distribution",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["last"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_databus_delivery_errors{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\",symbol=~\"$symbol\"}[5m])) by (error)",
          "legendFormat": "{{error}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(meltica_dispatcher_events_dropped{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\",symbol=~\"$symbol\"}[5m])) by (provider)",
          "legendFormat": "blocked {{provider}}",
          "refId": "B"
        }
      ],
      "title": "Delivery Errors by Cause",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "custom": {
            "align": "center"
          },
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 5,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(10, sum(meltica_databus_subscribers{environment=\"$environment\",provider=~\"$provider\",event_type=~\"$event_type\",symbol=~\"$symbol\"}) by (event_type, symbol))",
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Top Subscribed Streams",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Value": false
            },
            "indexByName": {
              "Value": 2
            },
            "renameByName": {
              "event_type": "Event Type",
              "symbol": "Symbol",
              "Value": "Subscribers"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
