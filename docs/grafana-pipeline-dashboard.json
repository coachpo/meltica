{
  "title": "Meltica Event Pipeline Metrics",
  "uid": "meltica-pipeline-metrics",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "query": "label_values(meltica_dispatcher_events_ingested, environment)",
        "datasource": {"type": "prometheus", "uid": null},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "event_type",
        "type": "query",
        "label": "Event Type",
        "query": "label_values(meltica_dispatcher_events_ingested{environment=~\"$environment\"}, event_type)",
        "datasource": {"type": "prometheus", "uid": null},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "provider",
        "type": "query",
        "label": "Provider",
        "query": "label_values(meltica_dispatcher_events_ingested{environment=~\"$environment\"}, provider)",
        "datasource": {"type": "prometheus", "uid": null},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "symbol",
        "type": "query",
        "label": "Symbol",
        "query": "label_values(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\"}, symbol)",
        "datasource": {"type": "prometheus", "uid": null},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "title": "Ingestion Rate (R)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "blue"
              },
              {
                "value": 100,
                "color": "green"
              },
              {
                "value": 500,
                "color": "yellow"
              },
              {
                "value": 1000,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate (E)",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])) + sum(rate(meltica_databus_delivery_errors{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          },
          "unit": "ops",
          "decimals": 3
        }
      }
    },
    {
      "title": "Processing Latency p99 (D)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, event_type) (rate(meltica_dispatcher_processing_duration_milliseconds_bucket{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 400,
                "color": "yellow"
              },
              {
                "value": 800,
                "color": "red"
              }
            ]
          },
          "unit": "ms",
          "decimals": 1
        }
      }
    },
    {
      "title": "Active Subscribers",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(meltica_databus_subscribers{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\"})",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      }
    },
    {
      "title": "Operational KPIs",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "Event Flow: Ingestion \u2192 Publishing",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "A",
          "legendFormat": "Ingested - {{event_type}}"
        },
        {
          "expr": "sum by (event_type) (rate(meltica_databus_events_published{environment=~\"$environment\", event_type=~\"$event_type\", event_provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "B",
          "legendFormat": "Published - {{event_type}}"
        },
        {
          "expr": "sum by (event_type) (rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "C",
          "legendFormat": "Dropped - {{event_type}}"
        },
        {
          "expr": "sum by (event_type) (rate(meltica_databus_delivery_errors{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "D",
          "legendFormat": "Delivery Errors - {{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "C"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "title": "Events by Provider",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (provider) (rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "sum"
          ]
        }
      }
    },
    {
      "title": "Events by Type",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "sum"
          ]
        }
      }
    },
    {
      "title": "Processing Duration (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, event_type) (rate(meltica_dispatcher_processing_duration_milliseconds_bucket{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "A",
          "legendFormat": "{{event_type}} - p99"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, event_type) (rate(meltica_dispatcher_processing_duration_milliseconds_bucket{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "B",
          "legendFormat": "{{event_type}} - p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, event_type) (rate(meltica_dispatcher_processing_duration_milliseconds_bucket{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "C",
          "legendFormat": "{{event_type}} - p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2
          },
          "unit": "ms"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "title": "Buffered Events",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 21,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "meltica_dispatcher_events_buffered{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}",
          "refId": "A",
          "legendFormat": "Buffered Events"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 100,
                "color": "yellow"
              },
              {
                "value": 500,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        }
      }
    },
    {
      "title": "Subscribers by Event Type",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "meltica_databus_subscribers{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\"}",
          "refId": "A",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        }
      }
    },
    {
      "title": "Delivery Errors",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (error, event_type) (rate(meltica_databus_delivery_errors{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{event_type}} - {{error}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 2,
            "fillOpacity": 50
          },
          "unit": "ops",
          "color": {
            "mode": "palette-classic",
            "fixedColor": "red"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "title": "Duplicate Events Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(meltica_dispatcher_events_duplicate{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 2,
            "fillOpacity": 50
          },
          "unit": "ops",
          "color": {
            "mode": "palette-classic",
            "fixedColor": "orange"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "title": "Event Drop Reasons",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 37,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (reason, event_type) (rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{event_type}} - {{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 2,
            "fillOpacity": 50
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "title": "Pipeline Health Summary",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 45,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type, provider, symbol) (rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "Ingested",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (event_type) (rate(meltica_databus_events_published{environment=~\"$environment\", event_type=~\"$event_type\", event_provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "Published",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (event_type) (rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "Dropped",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (event_type) (rate(meltica_dispatcher_events_duplicate{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "Duplicate",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (event_type) (meltica_databus_subscribers{environment=~\"$environment\", event_type=~\"$event_type\"})",
          "refId": "Subscribers",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "event_type": "Event Type",
              "provider": "Provider",
              "Value #Ingested": "Ingestion Rate",
              "Value #Published": "Publish Rate",
              "Value #Dropped": "Drop Rate",
              "Value #Duplicate": "Duplicate Rate",
              "Value #Subscribers": "Subscribers"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Ingestion Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Publish Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Drop Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 3
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "value": 0,
                      "color": "green"
                    },
                    {
                      "value": 0.1,
                      "color": "yellow"
                    },
                    {
                      "value": 1,
                      "color": "red"
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Duplicate Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 3
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Subscribers"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Ingestion Rate",
            "desc": true
          }
        ]
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "datasource": {"type": "prometheus", "uid": null},
        "enable": true,
        "name": "Deployments",
        "iconColor": "blue",
        "tags": [
          "deployment"
        ]
      }
    ]
  }
}