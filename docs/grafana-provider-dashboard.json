    {
      "title": "Dispatcher Flow",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "Ingested vs Dropped by Provider",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (provider) (rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", provider=~\"$provider\", event_type=~\"$event_type\", symbol=~\"$symbol\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "Ingested - {{provider}}"
        },
        {
          "expr": "sum by (provider) (rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", provider=~\"$provider\", event_type=~\"$event_type\", symbol=~\"$symbol\"}[$__rate_interval]))",
          "refId": "B",
          "legendFormat": "Dropped - {{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "title": "Drop Rate by Reason",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", provider=~\"$provider\", event_type=~\"$event_type\", symbol=~\"$symbol\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 70
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "title": "Latency & Buffering",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "Processing Latency Quantiles",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(meltica_dispatcher_processing_duration_bucket{environment=~\"$environment\"}[$__rate_interval])))",
          "refId": "P50",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(meltica_dispatcher_processing_duration_bucket{environment=~\"$environment\"}[$__rate_interval])))",
          "refId": "P95",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(meltica_dispatcher_processing_duration_bucket{environment=~\"$environment\"}[$__rate_interval])))",
          "refId": "P99",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
