    {
      "title": "Fanout Size Quantiles",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 16,
        "y": 29,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, event_type) (rate(meltica_databus_fanout_size_bucket{environment=~\"$environment\", event_type=~\"$event_type\"}[$__rate_interval])))",
          "refId": "P50",
          "legendFormat": "p50 {{event_type}}"
