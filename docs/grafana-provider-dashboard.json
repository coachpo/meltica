      },
      "gridPos": {
        "x": 18,
        "y": 6,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg(avg_over_time(meltica_dispatcher_events_buffered{environment=~\"$environment\", provider=~\"$provider\", event_type=~\"$event_type\", symbol=~\"$symbol\"}[$__rate_interval]))",
