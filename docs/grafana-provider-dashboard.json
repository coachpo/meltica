      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_duplicate{environment=~\"$environment\", provider=~\"$provider\", event_type=~\"$event_type\", symbol=~\"$symbol\"}[$__rate_interval]))",
