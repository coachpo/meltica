{
  "title": "Meltica System Overview",
  "uid": "meltica-system-overview",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "query": "label_values(meltica_dispatcher_events_ingested, environment)",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "label": "Provider",
        "query": "label_values(meltica_dispatcher_events_ingested{environment=~\"$environment\"}, provider)",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "System Health",
      "type": "row",
      "id": 1,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Ingestion Rate",
      "type": "stat",
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "Events/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 100,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Delivery Rate",
      "type": "stat",
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_databus_events_published{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "Events/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 100,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval])) + sum(rate(meltica_databus_delivery_errors{environment=~\"$environment\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "Errors/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Pool Pressure",
      "type": "stat",
      "id": 5,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "max(meltica_pool_objects_active{environment=~\"$environment\"} / meltica_pool_capacity{environment=~\"$environment\"})",
          "refId": "A",
          "legendFormat": "Max Utilization"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.8,
                "color": "yellow"
              },
              {
                "value": 0.95,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Orderbook Quality",
      "type": "stat",
      "id": 6,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "1 - clamp_max((sum(rate(meltica_orderbook_gap_detected{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval])) * 10 + sum(rate(meltica_orderbook_update_stale{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval])) * 5), 1)",
          "refId": "A",
          "legendFormat": "Quality Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 0.9,
                "color": "yellow"
              },
              {
                "value": 0.99,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "System Uptime",
      "type": "stat",
      "id": 7,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval])) / sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval])))) * 100",
          "refId": "A",
          "legendFormat": "Availability"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 99,
                "color": "yellow"
              },
              {
                "value": 99.9,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Event Flow Pipeline",
      "type": "row",
      "id": 10,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Event Flow Funnel",
      "type": "timeseries",
      "id": 11,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "Ingested"
        },
        {
          "expr": "sum(rate(meltica_databus_events_published{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval]))",
          "refId": "B",
          "legendFormat": "Published to Databus"
        },
        {
          "expr": "-sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval]))",
          "refId": "C",
          "legendFormat": "Dropped (leakage)"
        },
        {
          "expr": "-sum(rate(meltica_databus_delivery_errors{environment=~\"$environment\"}[$__rate_interval]))",
          "refId": "D",
          "legendFormat": "Delivery Errors (leakage)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Dropped (leakage)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Delivery Errors (leakage)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "title": "Component Health Status",
      "type": "row",
      "id": 20,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Provider Health",
      "type": "stat",
      "id": 21,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_provider_reconnections{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval])) * 60",
          "refId": "A",
          "legendFormat": "Reconnections/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.01,
                "color": "yellow"
              },
              {
                "value": 0.1,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Dispatcher Health",
      "type": "stat",
      "id": 22,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 5,
        "y": 15,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(meltica_dispatcher_processing_duration_bucket{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval])) by (le))",
          "refId": "A",
          "legendFormat": "p99 Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 50,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Databus Health",
      "type": "stat",
      "id": 23,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 10,
        "y": 15,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "(sum(rate(meltica_databus_delivery_errors{environment=~\"$environment\"}[$__rate_interval])) / sum(rate(meltica_databus_events_published{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval]))) * 100",
          "refId": "A",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Pool Health",
      "type": "stat",
      "id": 24,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 15,
        "y": 15,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "max(meltica_pool_objects_active{environment=~\"$environment\"} / meltica_pool_capacity{environment=~\"$environment\"}) * 100",
          "refId": "A",
          "legendFormat": "Max Utilization"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 80,
                "color": "yellow"
              },
              {
                "value": 95,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Orderbook Health",
      "type": "stat",
      "id": 25,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 19,
        "y": 15,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_orderbook_gap_detected{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "Gap Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 4,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.01,
                "color": "yellow"
              },
              {
                "value": 0.1,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Event Type Distribution",
      "type": "row",
      "id": 30,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Ingestion by Event Type",
      "type": "timeseries",
      "id": 31,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", provider=~\"$provider\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{ event_type }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 70,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    }
  ],
  "annotations": {
    "list": []
  },
  "links": [
    {
      "title": "Event Pipeline Details",
      "url": "/d/meltica-provider-health",
      "icon": "external link",
      "type": "link"
    },
    {
      "title": "Pool Health Details",
      "url": "/d/meltica-pool-usage",
      "icon": "external link",
      "type": "link"
    },
    {
      "title": "Orderbook Quality Details",
      "url": "/d/meltica-orderbook",
      "icon": "external link",
      "type": "link"
    }
  ]
}
