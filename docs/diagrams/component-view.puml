@startuml
title Component View (Monolith Boundaries)

package "Monolith Process" {
  [Control Bus Handler] as Ctrl
  [Orchestrator] as Orc
  [Dispatcher] as Disp
  [Data Bus] as DBus
  [Telemetry] as Tlm
  [Recycler] as Recycler

  package "Providers" {
    component "Provider O\nWS+REST+Adapter\n+ Book Assembler" as PO
    component "Provider P\nWS+REST+Adapter\n+ Book Assembler" as PP
    component "Provider Q\nWS+REST+Adapter\n+ Book Assembler" as PQ
  }

  package "Consumers" {
    component "Consumer A (lambda)" as CA
    component "Consumer B (lambda)" as CB
    component "Consumer C (lambda)" as CC
  }
}

PO --> Orc : Canonical Events
PP --> Orc
PQ --> Orc
Orc --> Disp : Merged/Canonical Events
Disp --> DBus
DBus --> CA
DBus --> CB
DBus --> CC

CA --> Ctrl : Control Commands
CB --> Ctrl : Control Commands
CC --> Ctrl : Control Commands
Ctrl --> Orc : Merge Configs
Ctrl --> Disp : Routing Tables (versioned)

Disp --> PO : Provider Orders (idempotent)
Disp --> PP
Disp --> PQ

Orc --> Tlm : merge.suppressed_partial / book.resync
Disp --> Tlm : backpressure.drop / dup.drop / throttle
@enduml
