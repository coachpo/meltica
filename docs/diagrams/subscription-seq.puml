@startuml
title Control Bus Atomicity: Subscribe (flip), SubmitOrder, QueryOrder

actor "Consumer lambda" as CON
queue "Control Bus" as CB
participant "Control Handler" as Ctrl
participant "Orchestrator" as Orc
participant "Dispatcher" as Disp
participant "Provider Adapter" as Prov
queue "Data Bus" as DBus

' Subscribe with atomic flip
CON -> CB : ControlCommand{cmd=Subscribe, consistency=at_version, reply_to=CON}
CB -> Ctrl : deliver
Ctrl -> Disp : stage NEXT routing table (v+1)
Ctrl -> Orc : stage NEXT merge configs (v+1)
alt ready
  Ctrl -> Ctrl : flip current_version v -> v+1
  Ctrl -> CB : RoutingFlip{from:v,to:v+1}
  Ctrl -> CB : CommandAck{accepted}
else fail
  Ctrl -> CB : CommandAck{rejected}
end

' Submit Order (immediate)
CON -> CB : ControlCommand{cmd=SubmitOrder, reply_to=CON, client_order_id=xyz}
CB -> Ctrl : deliver
Ctrl -> CB : CommandAck{accepted}
Ctrl -> Prov : ProviderOrder{client_order_id=xyz}
Prov -> Orc : ExecReport{ACK, routing_version=(current)}
Orc -> Disp : ExecReport
Disp -> DBus : publish (critical, always deliver)
DBus --> CON : ExecReport

' Query Order (immediate)
CON -> CB : ControlCommand{cmd=QueryOrder, reply_to=CON}
CB -> Ctrl : deliver
Ctrl -> Prov : QueryREST{...}
Prov -> Ctrl : QueryResultRaw{...}
Ctrl -> Disp : CommandResult{routing_version=(current), reply_to=CON}
Disp -> DBus : publish (critical)
DBus --> CON : CommandResult
@enduml
