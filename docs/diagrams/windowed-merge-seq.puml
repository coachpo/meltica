@startuml
title Orchestrator Windowed Merge (late=drop, partial=suppress)

participant "Binance Provider" as PRV
participant "Orchestrator" as Orc
participant "Dispatcher" as Disp

PRV -> Orc : Trade{symbol=BTC-USDT, k=BTC-USDT:Trade}
Orc -> Orc : open window for k=BTC-USDT:Trade (t0)
... within window ...
PRV -> Orc : Trade{symbol=BTC-USDT, k=BTC-USDT:Trade}
PRV -> Orc : Trade{symbol=BTC-USDT, k=BTC-USDT:Trade}
Orc -> Orc : close by time<=10s OR count<=1000
alt Complete (all events present)
  Orc -> Orc : tag routing_version=v+1
  Orc -> Disp : Merged{Trade1,Trade2,Trade3}
else Partial
  Orc -> Orc : drop window (suppress partial)
end
@enduml
