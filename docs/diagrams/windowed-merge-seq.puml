@startuml
title Orchestrator Windowed Merge (late=drop, partial=suppress)

participant "Provider O" as O
participant "Provider P" as P
participant "Orchestrator" as Orc
participant "Dispatcher" as Disp

O -> Orc : Canonical X{k=abc}
P -> Orc : Canonical Y{k=abc}
Orc -> Orc : open window for k=abc (t0)
... within window ...
O -> Orc : Canonical Z{k=abc}
Orc -> Orc : close by time<=10s OR count<=1000
alt Complete (X,Y,Z present)
  Orc -> Orc : tag routing_version
  Orc -> Disp : Merged{X,Y,Z}
else Partial
  Orc -> Orc : drop incomplete window
end
@enduml
