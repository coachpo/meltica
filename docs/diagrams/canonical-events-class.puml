@startuml
title Canonical Contracts (Class Diagram)

class CanonicalEvent {
  +event_id: String
  +provider: String
  +symbol: String
  +event_type: String
  +event_ts: Instant
  +ingest_ts: Instant
  +seq_provider: Long?
  +routing_version: Long
  +payload: Any
}

class MergedEvent {
  +merge_id: String
  +providers: List<String>
  +symbols: List<String>
  +event_types: List<String>
  +merge_key: Map<String,Any>
  +window_start: Instant
  +window_end: Instant
  +duration_ms: Long
  +count: Int
  +routing_version: Long
  +items: List<ItemRef>
}

class ItemRef { 
  +ref_event_id: String
  +payload: Any 
}

class OrderRequest {
  +client_order_id: String
  +provider: String
  +account: String
  +symbol: String
  +side: String
  +type: String
  +qty: Decimal
  +price: Decimal?
  +tif: String?
  +meta: Map<String,Any>
}

class ExecReport {
  +provider: String
  +account: String
  +symbol: String
  +client_order_id: String
  +provider_order_id: String?
  +status: String
  +filled_qty: Decimal
  +remaining_qty: Decimal
  +avg_price: Decimal?
  +reason: String?
  +event_ts: Instant
  +ingest_ts: Instant
  +routing_version: Long
}

class ControlCommand {
  +command_id: String
  +type: String
  +reply_to: String
  +consistency: String
  +timeout_ms: Long?
  +payload: Any
  +meta: Map<String,Any>
}

class CommandAck {
  +command_id: String
  +accepted: Boolean
  +reason: String?
}

class CommandResult {
  +command_id: String
  +result: Any
  +routing_version: Long
  +reply_to: String
}

CanonicalEvent "1" o- "*" ItemRef : payload
MergedEvent "1" o- "*" ItemRef
@enduml
