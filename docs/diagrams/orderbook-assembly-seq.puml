@startuml
title Provider-side Orderbook Assembly (Snapshot + Diffs)

participant "WS (coder/websocket)" as WS
participant "REST (snapshot)" as REST
participant "Book Assembler" as BA
participant "Orchestrator" as Orc

WS -> BA : Diff{seq=1001}
WS -> BA : Diff{seq=1003} (buffer)
REST -> BA : Snapshot{seq=1000, depth=N}
BA -> BA : Align snapshot; apply buffered diffs
WS -> BA : Diff{seq=1002}
BA -> BA : Apply 1002, then 1003; verify checksum
alt Gap or checksum mismatch
  BA -> REST : Snapshot refresh
  BA -> BA : Realign from fresh snapshot
end
BA -> Orc : Canonical BookUpdate/BookSnapshot
@enduml
