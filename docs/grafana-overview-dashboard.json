{
  "title": "Meltica System Overview",
  "uid": "meltica-system-overview",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "query": "label_values(meltica_dispatcher_events_ingested, environment)",
        "datasource": {"type": "prometheus", "uid": null},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "event_type",
        "type": "query",
        "label": "Event Type",
        "query": "label_values(meltica_dispatcher_events_ingested{environment=~\"$environment\"}, event_type)",
        "datasource": {"type": "prometheus", "uid": null},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "provider",
        "type": "query",
        "label": "Provider",
        "query": "label_values(meltica_dispatcher_events_ingested{environment=~\"$environment\"}, provider)",
        "datasource": {"type": "prometheus", "uid": null},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "symbol",
        "type": "query",
        "label": "Symbol",
        "query": "label_values(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\"}, symbol)",
        "datasource": {"type": "prometheus", "uid": null},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "title": "RED Summary",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "Ingestion Rate (R)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "blue"
              },
              {
                "value": 100,
                "color": "green"
              },
              {
                "value": 500,
                "color": "yellow"
              },
              {
                "value": 1000,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate (E)",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])) + sum(rate(meltica_databus_delivery_errors{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          },
          "unit": "ops",
          "decimals": 3
        }
      }
    },
    {
      "title": "Processing Latency p99 (D)",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(meltica_dispatcher_processing_duration_milliseconds_bucket{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 400,
                "color": "yellow"
              },
              {
                "value": 800,
                "color": "red"
              }
            ]
          },
          "unit": "ms",
          "decimals": 1
        }
      }
    },
    {
      "title": "System KPIs",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "Pool Utilization",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg(meltica_pool_objects_active{environment=~\"$environment\"} / meltica_pool_capacity{environment=~\"$environment\"})",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      }
    },
    {
      "title": "Orderbook Gaps",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 6,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_orderbook_gap_detected{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          },
          "unit": "ops",
          "decimals": 3
        }
      }
    },
    {
      "title": "Events Dropped",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          },
          "unit": "ops",
          "decimals": 3
        }
      }
    },
    {
      "title": "Delivery Errors",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_databus_delivery_errors{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          },
          "unit": "ops",
          "decimals": 3
        }
      }
    },
    {
      "title": "Active Subscribers",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 6,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(meltica_databus_subscribers{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\"})",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "title": "Event Pipeline",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "Event Flow",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "A",
          "legendFormat": "Ingested"
        },
        {
          "expr": "sum(rate(meltica_databus_events_published{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "B",
          "legendFormat": "Published"
        },
        {
          "expr": "sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "C",
          "legendFormat": "Dropped"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Dropped"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "title": "Event Types Distribution",
      "type": "piechart",
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum",
            "percent"
          ]
        },
        "pieType": "donut",
        "displayLabels": [
          "percent"
        ]
      }
    },
    {
      "title": "Memory Pools",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "Pool Utilization by Type",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "meltica_pool_objects_active{environment=~\"$environment\"} / meltica_pool_capacity{environment=~\"$environment\"}",
          "refId": "A",
          "legendFormat": "{{pool_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.7,
                "color": "yellow"
              },
              {
                "value": 0.9,
                "color": "red"
              }
            ]
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      }
    },
    {
      "title": "Pool Borrow Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (pool_name) (rate(meltica_pool_objects_borrowed_total{environment=~\"$environment\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{pool_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "sum"
          ]
        }
      }
    },
    {
      "title": "Orderbook Health",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "Snapshots & Gaps",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (symbol) (rate(meltica_orderbook_snapshot_applied{environment=~\"$environment\", symbol=~\"$symbol\"}[1m]))",
          "refId": "A",
          "legendFormat": "Snapshots - {{symbol}}"
        },
        {
          "expr": "sum by (symbol) (rate(meltica_orderbook_gap_detected{environment=~\"$environment\", symbol=~\"$symbol\"}[1m])) * 100",
          "refId": "B",
          "legendFormat": "Gaps (x100) - {{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "title": "Buffer Sizes",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "meltica_orderbook_buffer_size{environment=~\"$environment\", symbol=~\"$symbol\"}",
          "refId": "A",
          "legendFormat": "Orderbook - {{symbol}}"
        },
        {
          "expr": "meltica_dispatcher_events_buffered{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}",
          "refId": "B",
          "legendFormat": "Dispatcher"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        }
      }
    },
    {
      "title": "Performance",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "title": "Processing Latency p99",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, event_type) (rate(meltica_dispatcher_processing_duration_milliseconds_bucket{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "A",
          "legendFormat": "Dispatcher"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(meltica_pool_borrow_duration_milliseconds_bucket{environment=~\"$environment\"}[5m])))",
          "refId": "B",
          "legendFormat": "Pool Borrow"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(meltica_orderbook_coldstart_duration_milliseconds_bucket{environment=~\"$environment\", symbol=~\"$symbol\"}[5m])))",
          "refId": "C",
          "legendFormat": "Orderbook Cold Start"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2
          },
          "unit": "ms"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "title": "System Health Score",
      "type": "gauge",
      "gridPos": {
        "x": 12,
        "y": 38,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "100 * (1 - (sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])) / (sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\", event_type=~\"$event_type\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])) + 0.001)))",
          "refId": "A"
        }
      ],
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 95,
                "color": "yellow"
              },
              {
                "value": 99,
                "color": "green"
              }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "datasource": {"type": "prometheus", "uid": null},
        "enable": true,
        "name": "Deployments",
        "iconColor": "blue",
        "tags": [
          "deployment"
        ]
      }
    ]
  }
}