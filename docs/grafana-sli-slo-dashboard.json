{
  "title": "Meltica SLI/SLO Compliance",
  "uid": "meltica-sli-slo",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "query": "label_values(meltica_dispatcher_events_ingested, environment)",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "multi": false,
        "includeAll": false,
        "refresh": 2,
        "current": {
          "selected": false,
          "text": "production",
          "value": "production"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "SLO Compliance",
      "type": "row",
      "id": 1,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Availability SLI (Target: 99.9%)",
      "type": "stat",
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 5,
        "h": 5
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\"}[5m])) / sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\"}[5m])))) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 99,
                "color": "yellow"
              },
              {
                "value": 99.9,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Latency SLI (Target: p99 < 10ms)",
      "type": "stat",
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 5,
        "y": 1,
        "w": 5,
        "h": 5
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(meltica_dispatcher_processing_duration_bucket{environment=~\"$environment\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 50,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Error Rate SLI (Target: < 0.1%)",
      "type": "stat",
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 10,
        "y": 1,
        "w": 5,
        "h": 5
      },
      "targets": [
        {
          "expr": "(sum(rate(meltica_databus_delivery_errors{environment=~\"$environment\"}[5m])) / sum(rate(meltica_databus_events_published{environment=~\"$environment\"}[5m]))) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Orderbook Quality SLI (Target: > 99%)",
      "type": "stat",
      "id": 5,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 15,
        "y": 1,
        "w": 5,
        "h": 5
      },
      "targets": [
        {
          "expr": "(1 - clamp_max((sum(rate(meltica_orderbook_gap_detected{environment=~\"$environment\"}[5m])) * 10 + sum(rate(meltica_orderbook_update_stale{environment=~\"$environment\"}[5m])) * 5), 1)) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 95,
                "color": "yellow"
              },
              {
                "value": 99,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Pool Latency SLI (Target: p99 < 1ms)",
      "type": "stat",
      "id": 6,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(meltica_pool_borrow_duration_bucket{environment=~\"$environment\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "SLI Trends (24 hours)",
      "type": "row",
      "id": 10,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Availability Trend",
      "type": "timeseries",
      "id": 11,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\"}[5m])) / sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\"}[5m])))) * 100",
          "refId": "A",
          "legendFormat": "Availability %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 99,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 99.9,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "title": "Latency Trend (p50/p95/p99)",
      "type": "timeseries",
      "id": 12,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(meltica_dispatcher_processing_duration_bucket{environment=~\"$environment\"}[5m])) by (le))",
          "refId": "P50",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(meltica_dispatcher_processing_duration_bucket{environment=~\"$environment\"}[5m])) by (le))",
          "refId": "P95",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(meltica_dispatcher_processing_duration_bucket{environment=~\"$environment\"}[5m])) by (le))",
          "refId": "P99",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p99"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 3
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "title": "Error Budget",
      "type": "row",
      "id": 20,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Availability Error Budget (0.1% allowed in 30d)",
      "type": "gauge",
      "id": 21,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "100 - ((sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\"}[30d])) / sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\"}[30d]))) * 100 / 0.1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 20,
                "color": "orange"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 80,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Error Budget Burn Rate (24h)",
      "type": "timeseries",
      "id": 22,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 8,
        "y": 16,
        "w": 16,
        "h": 6
      },
      "targets": [
        {
          "expr": "(sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\"}[1h])) / sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\"}[1h]))) / 0.001",
          "refId": "A",
          "legendFormat": "Burn Rate (1x = on target)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 2,
                "color": "yellow"
              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
