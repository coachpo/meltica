      "targets": [
        {
          "expr": "(1 - (sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\"}[6h])) / sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\"}[6h])))) * 100",
          "refId": "A",
