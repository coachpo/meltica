    {
      "title": "SLI Compliance Summary",
      "type": "table",
      "id": 32,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(meltica_dispatcher_events_dropped{environment=~\"$environment\"}[24h])) / sum(rate(meltica_dispatcher_events_ingested{environment=~\"$environment\"}[24h])))) * 100",
          "refId": "Availability",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(meltica_dispatcher_processing_duration_bucket{environment=~\"$environment\"}[24h])) by (le))",
          "refId": "Latency",
          "format": "table",
          "instant": true
        },
        {
          "expr": "(sum(rate(meltica_databus_delivery_errors{environment=~\"$environment\"}[24h])) / sum(rate(meltica_databus_events_published{environment=~\"$environment\"}[24h]))) * 100",
          "refId": "ErrorRate",
          "format": "table",
          "instant": true
        },
        {
          "expr": "(1 - clamp_max((sum(rate(meltica_orderbook_gap_detected{environment=~\"$environment\"}[24h])) * 10 + sum(rate(meltica_orderbook_update_stale{environment=~\"$environment\"}[24h])) * 5), 1)) * 100",
          "refId": "BookQuality",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(meltica_pool_borrow_duration_bucket{environment=~\"$environment\"}[24h])) by (le))",
          "refId": "PoolLatency",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
