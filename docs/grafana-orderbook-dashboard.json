{
  "title": "Meltica Orderbook Metrics",
  "uid": "meltica-orderbook-metrics",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "hide": 0,
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "query": "label_values(meltica_orderbook_gap_detected, environment)",
        "datasource": null,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "symbol",
        "type": "query",
        "label": "Symbol",
        "query": "label_values(meltica_orderbook_gap_detected{environment=~\"$environment\"}, symbol)",
        "datasource": null,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "title": "Snapshot Applied Rate",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_orderbook_snapshot_applied{environment=~\"$environment\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      }
    },
    {
      "title": "Gap Detection Rate",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_orderbook_gap_detected{environment=~\"$environment\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.01,
                "color": "yellow"
              },
              {
                "value": 0.1,
                "color": "red"
              }
            ]
          },
          "unit": "ops",
          "decimals": 3
        }
      }
    },
    {
      "title": "Stale Update Rate",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_orderbook_update_stale{environment=~\"$environment\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 10,
                "color": "red"
              }
            ]
          },
          "unit": "ops",
          "decimals": 2
        }
      }
    },
    {
      "title": "Current Buffer Size",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(meltica_orderbook_buffer_size{environment=~\"$environment\", symbol=~\"$symbol\"})",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 50,
                "color": "red"
              }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Snapshot Applied Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(meltica_orderbook_snapshot_applied{environment=~\"$environment\", symbol=~\"$symbol\"}[1m])",
          "refId": "A",
          "legendFormat": "{{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "title": "Gap Detection Events",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(meltica_orderbook_gap_detected{environment=~\"$environment\", symbol=~\"$symbol\"}[1m])",
          "refId": "A",
          "legendFormat": "{{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 2,
            "fillOpacity": 50
          },
          "unit": "ops",
          "color": {
            "mode": "palette-classic",
            "fixedColor": "red"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "title": "Cold Start Duration (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(meltica_orderbook_coldstart_duration_bucket{environment=~\"$environment\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{symbol}} - p99"
        },
        {
          "expr": "histogram_quantile(0.95, rate(meltica_orderbook_coldstart_duration_bucket{environment=~\"$environment\", symbol=~\"$symbol\"}[5m]))",
          "refId": "B",
          "legendFormat": "{{symbol}} - p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(meltica_orderbook_coldstart_duration_bucket{environment=~\"$environment\", symbol=~\"$symbol\"}[5m]))",
          "refId": "C",
          "legendFormat": "{{symbol}} - p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2
          },
          "unit": "ms"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "title": "Buffer Size Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "meltica_orderbook_buffer_size{environment=~\"$environment\", symbol=~\"$symbol\"}",
          "refId": "A",
          "legendFormat": "{{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 50,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        }
      }
    },
    {
      "title": "Updates Replayed Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(meltica_orderbook_updates_replayed{environment=~\"$environment\", symbol=~\"$symbol\"}[1m])",
          "refId": "A",
          "legendFormat": "{{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "sum"
          ]
        }
      }
    },
    {
      "title": "Stale Updates Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(meltica_orderbook_update_stale{environment=~\"$environment\", symbol=~\"$symbol\"}[1m])",
          "refId": "A",
          "legendFormat": "{{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 2,
            "fillOpacity": 50
          },
          "unit": "ops",
          "color": {
            "mode": "palette-classic",
            "fixedColor": "orange"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "title": "Orderbook Health Summary",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(meltica_orderbook_snapshot_applied{environment=~\"$environment\", symbol=~\"$symbol\"}[5m])",
          "refId": "Snapshots",
          "format": "table",
          "instant": true
        },
        {
          "expr": "rate(meltica_orderbook_gap_detected{environment=~\"$environment\", symbol=~\"$symbol\"}[5m])",
          "refId": "Gaps",
          "format": "table",
          "instant": true
        },
        {
          "expr": "rate(meltica_orderbook_update_stale{environment=~\"$environment\", symbol=~\"$symbol\"}[5m])",
          "refId": "Stale",
          "format": "table",
          "instant": true
        },
        {
          "expr": "meltica_orderbook_buffer_size{environment=~\"$environment\", symbol=~\"$symbol\"}",
          "refId": "Buffer",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "symbol": "Symbol",
              "environment": "Environment",
              "Value #Snapshots": "Snapshot Rate (ops/s)",
              "Value #Gaps": "Gap Rate (ops/s)",
              "Value #Stale": "Stale Rate (ops/s)",
              "Value #Buffer": "Buffer Size"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Gap Rate (ops/s)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 3
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "value": 0,
                      "color": "green"
                    },
                    {
                      "value": 0.01,
                      "color": "yellow"
                    },
                    {
                      "value": 0.1,
                      "color": "red"
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Buffer Size"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "value": 0,
                      "color": "green"
                    },
                    {
                      "value": 10,
                      "color": "yellow"
                    },
                    {
                      "value": 50,
                      "color": "red"
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Snapshot Rate (ops/s)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Stale Rate (ops/s)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Gap Rate (ops/s)",
            "desc": true
          }
        ]
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "datasource": "$datasource",
        "enable": true,
        "name": "Deployments",
        "iconColor": "blue",
        "tags": [
          "deployment"
        ]
      }
    ]
  }
}