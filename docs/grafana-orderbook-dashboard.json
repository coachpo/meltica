{
  "title": "Meltica Orderbook Assembly",
  "uid": "meltica-orderbook",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "id": 2,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Overall Quality Score",
      "type": "stat",
      "id": 50,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 24,
        "h": 4
      },
      "targets": [
        {
          "expr": "1 - clamp_max((sum(rate(meltica_orderbook_gap_detected{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])) * 10 + sum(rate(meltica_orderbook_update_stale{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])) * 5), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 0.95,
                "color": "yellow"
              },
              {
                "value": 0.99,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Gap Rate (5m)",
      "type": "stat",
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_orderbook_gap_detected{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.01,
                "color": "yellow"
              },
              {
                "value": 0.1,
                "color": "red"
              }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "title": "Stale Update Rate (5m)",
      "type": "stat",
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_orderbook_update_stale{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.01,
                "color": "yellow"
              },
              {
                "value": 0.1,
                "color": "red"
              }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "title": "Snapshots Applied (5m)",
      "type": "stat",
      "id": 5,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(meltica_orderbook_snapshot_applied{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "title": "Buffered Updates",
      "type": "stat",
      "id": 6,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 18,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(meltica_orderbook_buffer_size{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 200,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Sequence Integrity",
      "type": "row",
      "id": 7,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Gap Rate by Symbol",
      "type": "timeseries",
      "id": 8,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (symbol, provider) (rate(meltica_orderbook_gap_detected{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{provider}} {{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "title": "Buffered Updates",
      "type": "timeseries",
      "id": 9,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "meltica_orderbook_buffer_size{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}",
          "refId": "A",
          "legendFormat": "{{provider}} {{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 200,
                "color": "red"
              }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        }
      }
    },
    {
      "title": "Recovery",
      "type": "row",
      "id": 10,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Recovery Pattern (Gaps \u2192 Buffer Buildup \u2192 Ready)",
      "type": "timeseries",
      "id": 51,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (provider, symbol) (rate(meltica_orderbook_gap_detected{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[1m]))",
          "refId": "Gaps",
          "legendFormat": "Gaps {{provider}}-{{symbol}}"
        },
        {
          "expr": "avg by (provider, symbol) (meltica_orderbook_buffer_size{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}) / 10",
          "refId": "Buffer",
          "legendFormat": "Buffer/10 {{provider}}-{{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "Gaps"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              },
              {
                "id": "custom.drawStyle",
                "value": "bars"
              },
              {
                "id": "custom.fillOpacity",
                "value": 60
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "Buffer"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "title": "Cold Start Duration Quantiles",
      "type": "timeseries",
      "id": 11,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, provider, symbol) (rate(meltica_orderbook_coldstart_duration_bucket{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "P50",
          "legendFormat": "p50 {{provider}} {{symbol}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider, symbol) (rate(meltica_orderbook_coldstart_duration_bucket{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "P95",
          "legendFormat": "p95 {{provider}} {{symbol}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, provider, symbol) (rate(meltica_orderbook_coldstart_duration_bucket{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "P99",
          "legendFormat": "p99 {{provider}} {{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
      "title": "WebSocket Health",
      "type": "row",
      "id": 13,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 1
      }
    },
    {
      "title": "Provider Reconnections",
      "type": "timeseries",
      "id": 14,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (provider, reason) (rate(meltica_provider_reconnections{environment=~\"$environment\", provider=~\"$provider\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{provider}} {{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      }
    },
    {
      "title": "WS Frame Borrow Latency",
      "type": "timeseries",
      "id": 15,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(meltica_pool_borrow_duration_bucket{environment=~\"$environment\", pool_name=\"WsFrame\"}[5m])))",
          "refId": "P99",
          "legendFormat": "WsFrame p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
      "title": "Orderbook Summary",
      "type": "table",
      "id": 16,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (provider, symbol) (rate(meltica_orderbook_gap_detected{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "GapRate",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (provider, symbol) (rate(meltica_orderbook_update_stale{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "StaleRate",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (provider, symbol) (rate(meltica_orderbook_snapshot_applied{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m]))",
          "refId": "SnapshotRate",
          "format": "table",
          "instant": true
        },
        {
          "expr": "avg by (provider, symbol) (meltica_orderbook_buffer_size{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"})",
          "refId": "BufferAvg",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, provider, symbol) (rate(meltica_orderbook_coldstart_duration_bucket{environment=~\"$environment\", provider=~\"$provider\", symbol=~\"$symbol\"}[5m])))",
          "refId": "ColdstartP99",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "cluster": true,
              "deployment_environment": true,
              "environment": true,
              "exported_job": true,
              "host_name": true,
              "os_type": true,
              "process_runtime_name": true,
              "process_runtime_version": true,
              "service": true,
              "service_name": true,
              "service_version": true
            },
            "indexByName": {
              "provider": 0,
              "symbol": 1,
              "Value #GapRate": 2,
              "Value #StaleRate": 3,
              "Value #SnapshotRate": 4,
              "Value #BufferAvg": 5,
              "Value #ColdstartP99": 6
            },
            "renameByName": {
              "provider": "Provider",
              "symbol": "Symbol",
              "Value #GapRate": "Gap Rate",
              "Value #StaleRate": "Stale Rate",
              "Value #SnapshotRate": "Snapshot Rate",
              "Value #BufferAvg": "Buffered Avg",
              "Value #ColdstartP99": "Coldstart p99"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Gap Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 3
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Stale Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 3
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Snapshot Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Buffered Avg"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Coldstart p99"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "current": {}
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(meltica_orderbook_gap_detected, environment)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "label": "Provider",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(meltica_orderbook_gap_detected{environment=~\"$environment\"}, provider)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "symbol",
        "type": "query",
        "label": "Symbol",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(meltica_orderbook_gap_detected{environment=~\"$environment\", provider=~\"$provider\"}, symbol)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": []
  },
