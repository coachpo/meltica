{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TradeEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["symbol", "price", "quantity", "time"],
  "properties": {
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9-]{3,}$"
    },
    "price": {
      "$ref": "#/definitions/decimal"
    },
    "quantity": {
      "$ref": "#/definitions/decimal"
    },
    "time": {
      "$ref": "#/definitions/timestamp"
    }
  },
  "definitions": {
    "decimal": {
      "type": "string",
      "pattern": "^-?[0-9]+(?:/[0-9]+)?$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}

