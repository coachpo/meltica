{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BalanceEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["balances"],
  "properties": {
    "balances": {
      "type": "array",
      "items": {"$ref": "#/definitions/balance"}
    }
  },
  "definitions": {
    "decimal": {
      "type": "string",
      "pattern": "^-?[0-9]+(?:/[0-9]+)?$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "balance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset", "available", "time"],
      "properties": {
        "asset": {
          "type": "string",
          "pattern": "^[A-Z0-9]{2,}$"
        },
        "available": {
          "$ref": "#/definitions/decimal"
        },
        "time": {
          "$ref": "#/definitions/timestamp"
        }
      }
    }
  }
}

